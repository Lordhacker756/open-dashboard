{
  "env": {
    "browser": true,
    "es2021": true
  },
  "extends": [
    "react-app",
    // "reat-app/jest",
    "airbnb",
    "plugin:prettier/recommended"
  ],
  "parserOptions": {
    "ecmaFeatures": {
      "jsx": true
    },
    "ecmaVersion": "latest",
    "sourceType": "module"
  },
  "plugins": ["react", "prettier"],
  "rules": {
    "prettier/prettier": [
      "error",
      {
        "endOfLine": "auto"
      }
    ],
    "quotes": [
      "error",
      "double",
      {
        "avoidEscape": true
      }
    ],
    "eslint linebreak-style": ["error", "windows"],
    "react/button-has-type": [
      "off",
      {
        "button": true,
        "submit": true,
        "reset": true
      }
    ],
    "linebreak-style": ["warn", "windows"]
  }
}
